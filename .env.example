# dsa110-operator secrets — copy to .env (git-ignored) OR to
# ~/.config/dsa110-operator/secrets.env, and fill in. NEVER commit real values.
#
# The console runs on YOUR laptop, bound to loopback and reached through the
# SSH tunnel to h23. There is no login server, so there are no SSO secrets.

# The one Anthropic key that funds the agent. Prefer a dedicated workspace
# key with a spend cap. Without it, the console falls back to the
# deterministic stub agent (monitoring + Q&A still work).
ANTHROPIC_API_KEY=

# Your operator name — used only as the audit/lease label so others can see
# who holds control. Defaults to your OS username if unset.
# DSA_OPERATOR_USER=vikram

# Stable secret for signing the session cookie (any long random string).
# Optional on a single laptop; set it to keep browser sessions across restarts.
DSA_OPERATOR_SECRET_KEY=

# Optional: Slack webhook for human-facing audit summaries + health alerts.
# DSA_OPERATOR_SLACK_WEBHOOK_URL=

# Optional: the agent model.
# DSA_OPERATOR_MODEL=claude-sonnet-4-5
