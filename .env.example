# dsa110-operator secrets — copy to .env (git-ignored) OR to
# ~/.config/dsa110-operator/secrets.env, and fill in. NEVER commit real values.
#
# Only the single operator SERVER process needs these. Monitoring users do
# NOT get a key — they sign in to the one console via Google SSO, and the
# server makes the Anthropic calls on the shared account.

# The one Anthropic key that funds the agent. Prefer a dedicated workspace
# key with a spend cap. Without it, the console falls back to the
# deterministic stub agent (monitoring + Q&A still work).
ANTHROPIC_API_KEY=

# Google OAuth (the console's sign-in). Authorize the redirect URI in the
# Google Cloud console: http://localhost:8787/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Who may sign in (monitoring). Either a domain allowlist or explicit emails.
DSA_OPERATOR_ALLOWED_DOMAINS=
# DSA_OPERATOR_ALLOWED_EMAILS=alice@example.org,bob@example.org

# Stable secret for signing the session cookie (any long random string).
DSA_OPERATOR_SECRET_KEY=

# Optional: Slack webhook for the human-facing audit summary.
# DSA_OPERATOR_SLACK_WEBHOOK_URL=

# Optional: the agent model.
# DSA_OPERATOR_MODEL=claude-sonnet-4-5
